# =============================================================================
# VitalLink Frontend — Environment Variables
# Copy to .env.local and fill in values before running locally or deploying.
# =============================================================================

# --- Backend API -------------------------------------------------------------
# URL of the deployed FastAPI backend (no trailing slash)
NEXT_PUBLIC_API_URL=https://your-app-name.onrender.com

# --- Supabase (Realtime) -----------------------------------------------------
# Project URL and anon key from Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# --- Demo --------------------------------------------------------------------
# Pre-registered requester UUID for the dashboard form (from seed_data.py output)
NEXT_PUBLIC_DEMO_REQUESTER_ID=
