# =============================================================================
# VitalLink Backend — Environment Variables
# Copy to .env and fill in values before running locally or deploying.
# =============================================================================

# --- Database (Supabase) ----------------------------------------------------
# Transaction-mode connection string from Supabase dashboard > Settings > Database
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vitallink

# --- Email (Resend) ---------------------------------------------------------
# Free-tier API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# --- Response links ----------------------------------------------------------
# Public URL of the frontend (for "I can help" email links)
BASE_URL=http://localhost:3000

# --- Security ----------------------------------------------------------------
# Secret key for signing JWT tokens in response links
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
RESPONSE_TOKEN_SECRET=dev-secret-change-in-production

# Token lifetime in days (default: 7)
RESPONSE_TOKEN_EXPIRY_DAYS=7
